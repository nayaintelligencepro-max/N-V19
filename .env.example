# ==================== SUPABASE ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your_anon_key
SUPABASE_SERVICE_KEY=eyJhbGciOi...your_service_key
