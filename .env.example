# ==================== ENVIRONMENT ====================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# ==================== API ====================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SECRET_KEY=change_this_in_production_key_here
JWT_SECRET=jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENCRYPTION_KEY=encryption_key_here

# ==================== DATABASE ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=naya_prod
DB_USER=naya_user
DB_PASSWORD=naya_secure_password_here
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ==================== REDIS CACHE ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=naya_redis_password_here
REDIS_DB=0
CACHE_TTL=3600

# ==================== VECTOR DATABASE ====================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_api_key_here

# ==================== MESSAGE BROKER ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=naya_user
RABBITMQ_PASSWORD=naya_rabbitmq_password_here

# ==================== CELERY ====================
CELERY_BROKER_URL=amqp://naya_user:naya_rabbitmq_password_here@localhost:5672//
CELERY_RESULT_BACKEND=redis://:naya_redis_password_here@localhost:6379/1

# ==================== ELASTICSEARCH ====================
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# ==================== PROMETHEUS ====================
PROMETHEUS_PORT=8001
ENABLE_METRICS=true

# ==================== MONITORING ====================
SENTRY_DSN=https://key@sentry.io/project-id
GRAFANA_PASSWORD=admin_password_here
GRAFANA_USER=admin

# ==================== EXTERNAL APIS - DATA ENRICHMENT ====================
SERPER_API_KEY=your_serper_api_key_here
APOLLO_API_KEY=your_apollo_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here

# ==================== EMAIL & COMMUNICATION ====================
SENDGRID_API_KEY=your_sendgrid_api_key_here
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret

# ==================== PAYMENT - STRIPE ====================
STRIPE_API_KEY=sk_live_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# ==================== PAYMENT - CRYPTO ====================
ALBY_API_KEY=your_alby_api_key_here
LND_HOST=localhost:8080
LND_CERT_PATH=/path/to/tls.cert
LND_MACAROON_PATH=/path/to/admin.macaroon

# ==================== PAYMENT - PAYPAL ====================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=live

# ==================== AI & LLM ====================
OPENAI_API_KEY=sk-your_openai_api_key
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key
HUGGINGFACE_API_KEY=hf_your_huggingface_key

# ==================== FEATURES ====================
ENABLE_VECTOR_MEMORY=true
ENABLE_SELF_HEALING=true
ENABLE_FEEDBACK_LOOP=true
ENABLE_LIGHTNING_PAYMENTS=true
ENABLE_SUBSCRIPTIONS=true

# ==================== DEPLOYMENT ====================
DOCKER_REGISTRY=your_docker_registry
DOCKER_IMAGE_TAG=latest
KUBERNETES_NAMESPACE=default

# ==================== SECURITY ====================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ==================== S3 / OBJECT STORAGE ====================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-1
S3_BUCKET_NAME=naya-prod-bucket

# ==================== ANALYTICS ====================
MIXPANEL_TOKEN=your_mixpanel_token
POSTHOG_API_KEY=your_posthog_key
POSTHOG_HOST=https://app.posthog.com
