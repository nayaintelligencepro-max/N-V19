# ==================== DEPLOYMENT ====================
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_TAG=latest
DOCKER_USERNAME=your_docker_username
DOCKER_TOKEN=dckr_pat_your_docker_token
RENDER_API_KEY=rnd_your_render_key
VERCEL_TOKEN=vcp_your_vercel_token
VERCEL_AI_KEY=vck_your_vercel_ai_key
KUBERNETES_NAMESPACE=default

# ==================== FEATURES - ALL TRUE IN PROD ====================
NAYA_PRODUCTION_MODE=true
ENABLE_VECTOR_MEMORY=true
ENABLE_SELF_HEALING=true
ENABLE_FEEDBACK_LOOP=true
ENABLE_LIGHTNING_PAYMENTS=true
ENABLE_SUBSCRIPTIONS=true
ENABLE_OUTREACH_EMAIL=true
ENABLE_OUTREACH_WHATSAPP=true
ENABLE_OUTREACH_TELEGRAM=true
ENABLE_PAIN_HUNT_AUTONOMOUS=true
ENABLE_GUARDIAN_AUTOSCAN=true
ENABLE_GUARDIAN_AUTOREPAIR=true
ENABLE_PARALLEL_PIPELINE=true
ENABLE_REVENUE_TRACKER=true
ENABLE_CONTRACT_GENERATOR=true

# ==================== SECURITY ====================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# ==================== S3 / OBJECT STORAGE ====================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=eu-west-1
S3_BUCKET_NAME=naya-prod-bucket

# ==================== ANALYTICS ====================
MIXPANEL_TOKEN=your_mixpanel_token
POSTHOG_API_KEY=your_posthog_key
POSTHOG_HOST=https://app.posthog.com
