# ═══════════════════════════════════════════════════════════════
# NAYA REAL SALES — Variables d'Environnement
# ═══════════════════════════════════════════════════════════════
# Copier ce fichier vers .env et remplir avec vos vraies clés
# JAMAIS committer le fichier .env avec de vraies clés !
# ═══════════════════════════════════════════════════════════════

# ── Configuration Générale ────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
LOG_LEVEL=INFO
TIMEZONE=Pacific/Tahiti

# ── Planchers et Seuils ───────────────────────────────────────────
MIN_CONTRACT_VALUE=1000
DECISION_THRESHOLD_EUR=500
MAX_PARALLEL_PROJECTS=4

# ── LLM APIs (au moins 1 requis) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxx
GROQ_API_KEY=gsk_xxx
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx
MISTRAL_API_KEY=xxx

# ── Paiements (REQUIS pour ventes réelles) ───────────────────────

# PayPal
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPALME_USERNAME=nayasupreme

# Deblock.me (Polynésie française)
DEBLOKME_SECRET_KEY=your_deblock_secret_key
DEBLOKME_WEBHOOK_SECRET=your_deblock_webhook_secret
DEBLOKME_PAYMENT_URL=https://pay.deblok.me

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Telegram Bot (REQUIS pour notifications) ──────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_OWNER_CHAT_ID=123456789

# ── Prospection APIs (optionnel, pour PainHunterAgent) ────────────
APOLLO_API_KEY=your_apollo_api_key
SERPER_API_KEY=your_serper_api_key
HUNTER_API_KEY=your_hunter_api_key

LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# ── Outreach APIs (optionnel) ─────────────────────────────────────
SENDGRID_API_KEY=SG.xxx
GMAIL_OAUTH=your_gmail_oauth_token
INSTANTLY_API_KEY=your_instantly_api_key
CALENDLY_API_KEY=your_calendly_api_key

# ── Mémoire Vectorielle (optionnel) ───────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-west1-gcp
CHROMA_HOST=localhost

# ── Base de Données ───────────────────────────────────────────────
DATABASE_URL=sqlite:///data/naya.db
REDIS_URL=redis://localhost:6379

# ── Sécurité ──────────────────────────────────────────────────────
ENCRYPTION_KEY=your_32_char_encryption_key_here
JWT_SECRET=your_jwt_secret_key_here
VAULT_KEY=your_vault_encryption_key

# ── Scheduler ─────────────────────────────────────────────────────
DAILY_BRIEFING_HOUR=8
GUARDIAN_SCAN_INTERVAL_H=6
LLM_TIMEOUT_S=10

# ═══════════════════════════════════════════════════════════════
# NOTES
# ═══════════════════════════════════════════════════════════════
#
# Variables MINIMUM pour ventes réelles :
# - TELEGRAM_BOT_TOKEN + TELEGRAM_OWNER_CHAT_ID
# - Au moins 1 provider paiement configuré
# - Au moins 1 LLM API (Groq recommandé pour gratuit)
#
# Variables optionnelles :
# - Apollo, Hunter, Serper : pour PainHunterAgent autonome
# - Pinecone : pour mémoire vectorielle cloud
# - Instantly : pour séquences outreach automatisées
#
# ═══════════════════════════════════════════════════════════════
